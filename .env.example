# Database
POSTGRES_USER=timetrak
POSTGRES_PASSWORD=timetrak
POSTGRES_DB=timetrak
POSTGRES_PORT=5432
DATABASE_URL=postgres://timetrak:timetrak@localhost:5432/timetrak?sslmode=disable

# HTTP server
HTTP_ADDR=:8080

# Session / security
# 32+ bytes, base64 or hex; rotate on incident.
SESSION_SECRET=change-me-to-a-long-random-value
# "true" in production (HTTPS); "false" for local HTTP dev.
COOKIE_SECURE=false

# Environment: "dev" | "prod"
APP_ENV=dev
